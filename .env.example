# ============================================================================
# QDK Chemistry - Quantum Dashboard Configuration (TEMPLATE)
# ============================================================================
# Copy this file to .env and fill in your values.
# ============================================================================

# --- Azure Quantum Workspace (Key-Based Authentication) ---
AZURE_QUANTUM_CONNECTION_STRING=
AZURE_QUANTUM_API_KEY=
AZURE_QUANTUM_ENDPOINT=https://eastus.quantum.azure.com/
AZURE_QUANTUM_RESOURCE_ID=
AZURE_QUANTUM_LOCATION=eastus
AZURE_QUANTUM_SUBSCRIPTION_ID=
AZURE_QUANTUM_RESOURCE_GROUP=
AZURE_QUANTUM_WORKSPACE_NAME=

# --- Authentication ---
# Primary: API key (embedded in connection string or AZURE_QUANTUM_API_KEY)
# Optional: Service-principal (uncomment if needed)
# AZURE_TENANT_ID=
# AZURE_CLIENT_ID=
# AZURE_CLIENT_SECRET=

QUANTINUUM_TARGET_SC=quantinuum.sim.h2-1sc
QUANTINUUM_TARGET_EM=quantinuum.sim.h2-1e

FLASK_APP=run.py
FLASK_ENV=development
FLASK_DEBUG=1
FLASK_SECRET_KEY=change-me-to-a-random-secret-key
FLASK_HOST=0.0.0.0
FLASK_PORT=5000
